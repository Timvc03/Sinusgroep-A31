import csv
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import pickle
import seaborn as sns
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix, ConfusionMatrixDisplay, roc_auc_score, RocCurveDisplay
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import root_mean_squared_error, roc_auc_score, accuracy_score
from sklearn.dummy import DummyRegressor, DummyClassifier

data_ev = pd.read_csv("churndata_deployment.csv")
data_test = pd.read_csv("data_test.csv")

# Haalt de logistische regressie op uit de lokale map.
with open('pipeline.pkl', 'rb') as file:
    log_reg_pipe = pickle.load(file)

log_reg_pipe.fit(data_ev, data_test['Churn'][:300])
p_pred = log_reg_pipe.predict_proba(data_ev)
y_train = LabelEncoder().fit_transform(data_test['Churn'][:300])

# Confusion matrix
ConfusionMatrixDisplay.from_predictions(y_train, (p_pred[:,1] > 0.6), cmap = 'Blues')
plt.show()

result = np.where((p_pred[:,1] > 0.6), 1, 0)

# Schrijft het resultaat van de churns weg als 0en of 1en in een kolom.
with open('result.csv', 'w', newline = '') as csvfile:
    writer = csv.writer(csvfile)

    for row in result.tolist():
        writer.writerow([row])

profit = 0.0

# Berekent de totale winst
for i in range(len(data_ev)):
    if (result[i] == 0):
        profit += (((data_ev['Seconds of Use'][i] / 60.0) * 0.07) + (data_ev['Frequency of SMS'][i] * 0.2))
    else:
        profit += (((data_ev['Seconds of Use'][i] / 60.0) * 0.1) + (data_ev['Frequency of SMS'][i] * 0.3))

print("De verwachte winst is: €" + str((round(profit, 2))))

# Plot 1
plt.figure(figsize = (12, 4))
plt.subplot(1, 3, 1)
sns.kdeplot(data_test[:300], x = p_pred[:,1], hue = 'Churn', fill = True)
plt.xlim(0, 1)
plt.title('Verdeling voorspelde kansen')

def make_row(cr):
    return {
        'Accuracy':  cr['accuracy'],
        'Recall':    cr['1']['recall'],
        'Precision': cr['1']['precision'],
        'F1 Score':  cr['1']['f1-score']
    }

thresholds = np.arange(0, 1, 0.01)
plot_data = pd.DataFrame([
    make_row(classification_report(
        y_train, 
        p_pred[:,1] > t, 
        zero_division = True, 
        output_dict = True)) for t in thresholds])
plot_data.index = thresholds

# Plot 2
plt.subplot(1, 3, 2)
sns.lineplot(plot_data)
plt.plot([0, 1], [0, 0], 'k:', alpha = 0.5, label = 'Nul Acc.')
plt.xlabel('Threshold')
plt.legend()
plt.title('Metric Plot')

# Plot 3
ax = plt.subplot(1, 3, 3)
roc = RocCurveDisplay.from_predictions(
    y_train, 
    p_pred[:,1], 
    name = '', 
    plot_chance_level = True,
    ax = ax)
plt.fill_between(roc.fpr, roc.tpr, color = '0.8')
plt.title('ROC curve')

